# Template for ~/.financeagent/secrets.properties
#
# Copy this file to your home directory at ~/.financeagent/secrets.properties
# and restrict permissions:
#   chmod 600 ~/.financeagent/secrets.properties                 (macOS / Linux)
#   icacls %USERPROFILE%\.financeagent\secrets.properties /inheritance:r /grant:r %USERNAME%:F     (Windows)
#
# Keys are namespaced as:
#   portals.<portalId>.<credential-key>=<value>
#
# The placeholder name used in a portal descriptor (e.g. ${credentials.username})
# maps directly to the part after "portals.<portalId>.".

# --- mock-portal (local Spring Boot testing-harness; credentials are public test values) ---
portals.mock-portal.credentials.username=admin
portals.mock-portal.credentials.password=password

# --- Example for a real portal (do NOT commit real values anywhere) ---
# portals.prod-payroll.credentials.username=...
# portals.prod-payroll.credentials.password=...
# portals.prod-payroll.credentials.tenant_id=...
