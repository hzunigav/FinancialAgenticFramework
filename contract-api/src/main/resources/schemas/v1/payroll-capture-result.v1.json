{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neoproc.com/financialagent/schemas/payroll-capture-result.v1.json",
  "title": "PayrollCaptureResult v1",
  "description": "Result of a payroll capture run from a source-of-truth portal (e.g., AutoPlanilla). Emitted by the agent-worker after captureToManifest, consumed by the BPM as input to subsequent submit Service Tasks.",
  "type": "object",
  "required": ["schema", "envelope", "task", "result", "audit"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "payroll-capture-result.v1" },

    "envelope": {
      "type": "object",
      "required": ["envelopeId", "businessKey", "firmId", "createdAt", "issuer", "issuerRunId"],
      "additionalProperties": false,
      "properties": {
        "envelopeId":  { "type": "string", "format": "uuid" },
        "businessKey": { "type": "string", "minLength": 1 },
        "firmId":      { "type": "integer", "minimum": 1 },
        "locale":      { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$", "default": "es" },
        "createdAt":   { "type": "string", "format": "date-time" },
        "issuer":      { "type": "string" },
        "issuerRunId": { "type": "string" }
      }
    },

    "task": {
      "type": "object",
      "required": ["type", "operation", "sourcePortal"],
      "additionalProperties": false,
      "properties": {
        "type":         { "const": "PAYROLL_CAPTURE" },
        "operation":    { "type": "string", "enum": ["CAPTURE"] },
        "sourcePortal": { "type": "string", "minLength": 1 },
        "period": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["from", "to"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string", "format": "date" },
                "to":   { "type": "string", "format": "date" }
              }
            }
          ]
        },
        "planilla": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["name"],
              "additionalProperties": false,
              "properties": {
                "id":   { "type": ["string", "null"] },
                "name": { "type": "string", "minLength": 1 }
              }
            }
          ]
        }
      }
    },

    "encryption": { "$ref": "#/$defs/Encryption" },

    "result": {
      "oneOf": [
        { "$ref": "#/$defs/CaptureResultBody" },
        { "type": "string", "pattern": "^vault:v\\d+:" }
      ]
    },

    "audit": { "$ref": "#/$defs/Audit" }
  },

  "$defs": {
    "Money": {
      "description": "Monetary value. Accepts either a JSON string (canonical wire form, e.g. '13870000.00') or a JSON number (Jackson default for BigDecimal). Both are equivalent on the wire; consumers should treat them as decimal.",
      "oneOf": [
        { "type": "string", "pattern": "^-?\\d+(\\.\\d{1,4})?$" },
        { "type": "number" }
      ]
    },
    "CaptureResultBody": {
      "type": "object",
      "required": ["status", "totals", "employees"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["SUCCESS", "PARTIAL", "MISMATCH", "FAILED"] },
        "totals": {
          "type": "object",
          "required": ["currency", "grossSalaries", "renta", "employeeCount"],
          "additionalProperties": false,
          "properties": {
            "currency":       { "type": "string", "pattern": "^[A-Z]{3}$" },
            "grossSalaries":  { "$ref": "#/$defs/Money" },
            "renta":          {
              "description": "Income tax withheld. Null when the source portal does not report renta (e.g. mock-payroll, some legacy portals); always populated for AutoPlanilla captures.",
              "oneOf": [
                { "type": "null" },
                { "$ref": "#/$defs/Money" }
              ]
            },
            "employeeCount":  { "type": "integer", "minimum": 0 }
          }
        },
        "employees": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "displayName", "grossSalary"],
            "additionalProperties": false,
            "properties": {
              "id":          { "type": "string", "minLength": 1 },
              "displayName": { "type": "string", "minLength": 1 },
              "grossSalary": { "$ref": "#/$defs/Money" },
              "attributes":  { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        }
      }
    },

    "Encryption": {
      "type": "object",
      "required": ["scheme", "keyName", "keyVersion", "ciphertextField"],
      "additionalProperties": false,
      "properties": {
        "scheme":          { "type": "string", "enum": ["vault-transit-v1", "kms-envelope-v1", "local-aes-gcm-v1"] },
        "keyName":         { "type": "string", "minLength": 1 },
        "keyVersion":      { "type": "integer", "minimum": 1 },
        "ciphertextField": { "type": "string", "enum": ["result"] }
      }
    },

    "Audit": {
      "type": "object",
      "required": ["payloadSha256"],
      "additionalProperties": false,
      "properties": {
        "manifestPath":     { "type": ["string", "null"] },
        "harSha256":        { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "screenshotSha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
        "payloadSha256":    { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
