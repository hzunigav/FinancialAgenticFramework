{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neoproc.com/financialagent/schemas/payroll-submit-request.v1.json",
  "title": "PayrollSubmitRequest v1",
  "description": "Input envelope to a target-portal submit Service Task (CCSS Sicere, INS RT-Virtual, Hacienda OVI, mock-payroll). Built by the BPM by composing the capture result with a target-portal flag. Consumed by the agent-worker's adapter.beforeSteps.",
  "type": "object",
  "required": ["schema", "envelope", "task", "request"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "payroll-submit-request.v1" },

    "envelope": { "$ref": "https://neoproc.com/financialagent/schemas/payroll-capture-result.v1.json#/properties/envelope" },

    "task": {
      "type": "object",
      "required": ["type", "operation", "targetPortal"],
      "additionalProperties": false,
      "properties": {
        "type":         { "const": "PAYROLL_SUBMIT" },
        "operation":    { "type": "string", "enum": ["SUBMIT_SALARIES", "SUBMIT_RENTA_DECLARATION"] },
        "targetPortal": { "type": "string", "enum": ["ccss-sicere", "ins-rt-virtual", "hacienda-ovi", "mock-payroll"] },
        "sourceCaptureEnvelopeId": { "type": "string", "format": "uuid",
          "description": "envelopeId of the upstream capture envelope this submission derives from. Lets the agent and BPM trace cause-and-effect." },
        "clientIdentifier": { "type": "string",
          "description": "Required for shared-creds and per-client portals. (a) shared-creds: the portal-side identifier (cédula jurídica, internal client code, etc.) that selects which client to act on after NeoProc's shared login. (b) per-client: the corporate id used both as the secret-path segment for credential resolution (financeagent/firms/<firmId>/portals/<portalId>/<clientIdentifier>) and, where applicable, for portal-side verification. Omit for per-firm portals." },
        "period":   { "$ref": "https://neoproc.com/financialagent/schemas/payroll-capture-result.v1.json#/properties/task/properties/period" },
        "planilla": { "$ref": "https://neoproc.com/financialagent/schemas/payroll-capture-result.v1.json#/properties/task/properties/planilla" }
      }
    },

    "encryption": { "$ref": "#/$defs/Encryption" },

    "request": {
      "oneOf": [
        { "$ref": "#/$defs/SubmitRequestBody" },
        { "type": "string", "pattern": "^(vault|kms):v\\d+:" }
      ]
    },

    "audit": { "$ref": "https://neoproc.com/financialagent/schemas/payroll-capture-result.v1.json#/$defs/Audit" }
  },

  "$defs": {
    "Encryption": {
      "type": "object",
      "required": ["scheme", "keyName", "keyVersion", "ciphertextField"],
      "additionalProperties": false,
      "properties": {
        "scheme":          { "type": "string", "enum": ["vault-transit-v1", "kms-envelope-v1"] },
        "keyName":         { "type": "string", "minLength": 1 },
        "keyVersion":      { "type": "integer", "minimum": 1 },
        "ciphertextField": { "type": "string", "enum": ["request"] }
      }
    },

    "SubmitRequestBody": {
      "type": "object",
      "required": ["employees"],
      "additionalProperties": false,
      "properties": {
        "employees": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "displayName", "salary"],
            "additionalProperties": false,
            "properties": {
              "id":          { "type": "string", "minLength": 1 },
              "displayName": { "type": "string", "minLength": 1 },
              "salary":      { "$ref": "https://neoproc.com/financialagent/schemas/payroll-capture-result.v1.json#/$defs/Money" },
              "attributes":  { "type": "object", "additionalProperties": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
